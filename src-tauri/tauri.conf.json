{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "differ",
  "version": "0.0.3",
  "identifier": "com.raodrin.differ",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "differ",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "noirLang",
    "homepage": "https://github.com/noirlang/differ",
    "license": "GPL-3.0-or-later",
    "category": "DeveloperTool",
    "shortDescription": "Git change explorer",
    "longDescription": "differ is a focused desktop Git change explorer for commit history, contributors, diffs, working tree status, and repository sync state.",
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "ca-certificates",
          "git",
          "gnupg",
          "librsvg2-2",
          "libsoup-3.0-0",
          "libssl3",
          "xdg-utils"
        ]
      },
      "rpm": {
        "depends": [
          "ca-certificates",
          "git",
          "gnupg2",
          "gtk3",
          "librsvg2",
          "libsoup3",
          "openssl-libs",
          "webkit2gtk4.1",
          "xdg-utils"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
